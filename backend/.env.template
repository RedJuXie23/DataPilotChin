# LLM Configuration (at least one provider key is required)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# LLM generation and per-agent timeouts
DATAPILOT_LLM_MAX_TOKENS=32768
DATAPILOT_LLM_REQUEST_TIMEOUT_SECONDS=1800
DATAPILOT_DATASET_DESCRIPTION_TIMEOUT_SECONDS=1860
DATAPILOT_CHANCELLOR_TIMEOUT_SECONDS=1860
DATAPILOT_COMMANDER_TIMEOUT_SECONDS=1860
DATAPILOT_EXECUTOR_AGENT_TIMEOUT_SECONDS=1860
DATAPILOT_CENSOR_TIMEOUT_SECONDS=1860
DATAPILOT_HELPER_AGENT_TIMEOUT_SECONDS=1860
DATAPILOT_LEGACY_AGENT_TIMEOUT_SECONDS=1860
DATAPILOT_LEGACY_PLANNER_TIMEOUT_SECONDS=1860

# Generated Python execution limits
DATAPILOT_CODE_EXECUTION_TIMEOUT_SECONDS=600
DATAPILOT_CODE_EXECUTION_GRACE_SECONDS=60
DATAPILOT_PLOTLY_EXPORT_TIMEOUT_SECONDS=120

# Intermediate analysis context limits for local multi-file workflows
DATAPILOT_CONTEXT_ITEM_MB=64
DATAPILOT_CONTEXT_TOTAL_MB=256

# Server
HOST=0.0.0.0
PORT=8001
